{
  "Frontend": {
    "Origin": "http://localhost:3000"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ConnectionStrings": {
    "Identity": "Host=postgres;Port=5432;Database=c4_identity;Username=postgres;Password=postgres",
    "Telemetry": "Host=postgres;Port=5432;Database=c4_telemetry;Username=postgres;Password=postgres",
    "Graph": "Host=postgres;Port=5432;Database=c4_graph;Username=postgres;Password=postgres",
    "Discovery": "Host=postgres;Port=5432;Database=c4_discovery;Username=postgres;Password=postgres",
    "Visualization": "Host=postgres;Port=5432;Database=c4_visualization;Username=postgres;Password=postgres",
    "Feedback": "Host=postgres;Port=5432;Database=c4_feedback;Username=postgres;Password=postgres"
  },
  "Jwt": {
    "SigningKey": "c4-development-signing-key-min-32-chars!!",
    "Issuer": "c4-api",
    "Audience": "c4-web",
    "ExpirationMinutes": 1440
  },
  "SemanticKernel": {
    "Ollama": {
      "Endpoint": "http://localhost:11434",
      "ChatModel": "mistral-large-3:675b-cloud"
    },
    "RemoteMcpServers": [
      {
        "Name": "default",
        "Endpoint": "http://localhost:8765",
        "AuthMode": "None",
        "TimeoutSeconds": 30
      }
    ],
    "ToolFiltersByEnvironment": {
      "Development": {
        "AllowList": [],
        "DenyList": []
      },
      "Production": {
        "AllowList": [],
        "DenyList": []
      }
    },
    "PlannerExecutionLimits": {
      "MaxSteps": 12,
      "MaxRetries": 3,
      "Budget": 1.0
    }
  }
}
